{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://amipgrjksrszocfzucxn.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "flowcare-mcp",
      "version": "0.1.0",
      "title": "FlowCare Clinic MCP"
    },
    "tools": [
      {
        "name": "search_patients",
        "title": "Search patients",
        "description": "Search patients in the signed-in user's clinic by name, phone, or email. Returns up to 20 matches.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "description": "Free-text query matched against name, phone, or email."
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_appointments",
        "title": "List appointments",
        "description": "List appointments in the signed-in user's clinic for a given date (YYYY-MM-DD). Defaults to today.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "date": {
              "description": "Date in YYYY-MM-DD. Defaults to today (UTC).",
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_therapy_sessions",
        "title": "List therapy sessions",
        "description": "List therapy sessions in the signed-in user's clinic for a given date (YYYY-MM-DD). Defaults to today.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "date": {
              "description": "Date in YYYY-MM-DD. Defaults to today (UTC).",
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
